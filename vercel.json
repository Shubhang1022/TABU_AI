{
  "version": 2,
  "rewrites": [
    { "source": "/api/chat", "destination": "/api/chat" },
    { "source": "/api/vision", "destination": "/api/vision" },
    { "source": "/api/speech", "destination": "/api/speech" },
    { "source": "/api/history", "destination": "/api/history" },
    { "source": "/api/sessions/(.*)", "destination": "/api/sessions" },
    { "source": "/api/sessions", "destination": "/api/sessions" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
